# =============================================================================
# Debate 2 Decision AI - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your API keys.
#   cp .env.example .env
# =============================================================================

# --- REQUIRED ---

# Groq API Key (LLM for debate generation)
# Get your free key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# --- OPTIONAL (for AI-generated illustrated avatar portraits) ---

# Hugging Face API Token (FLUX.1 via free HF Spaces -- recommended)
# Get your token at: https://huggingface.co/settings/tokens
# Generates Pixar-style illustrated characters for free
HF_API_TOKEN=

# Together.ai API Key (FLUX.1-schnell-Free model -- faster alternative)
# Get your key at: https://api.together.ai/settings/api-keys
TOGETHER_API_KEY=

# --- OPTIONAL (for AI talking head video generation) ---

# D-ID API Key (creates real talking head videos from avatar + text)
# Sign up free at: https://www.d-id.com/
# Get your key at: https://studio.d-id.com/account
# Free trial: ~5 min of video / 20 credits
# Without this key, the system uses canvas-based lip sync animation instead
D_ID_API_KEY=
